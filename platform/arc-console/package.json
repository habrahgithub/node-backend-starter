{
  "name": "arc-console",
  "version": "0.13.0-rc1",
  "private": true,
  "description": "Unified ARC control console with Express API and integrated dashboard server.",
  "type": "module",
  "engines": {
    "node": ">=20.11.1"
  },
  "scripts": {
    "dev": "NODE_ENV=development node --watch server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "api:dev": "NODE_ENV=development node --watch server/index.js",
    "dashboard:dev": "next dev dashboard -p 4110",
    "dashboard:build": "next build dashboard",
    "dashboard:start": "next start dashboard -p 4110",
    "lint": "eslint .",
    "test": "node --test tests/*.test.js tests/**/*.test.js",
    "verify": "npm run lint && npm run test && npm run dashboard:build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "next": "^16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.1.6"
  }
}
