# Ignore dependency folders (critical memory impact)
node_modules/
**/node_modules/
vendor/
packages/*/node_modules/

# Ignore version control and IDE metadata
.git/
**/.git/
.svn/
.vscode/
.idea/
**/.vscode/
**/.idea/

# Ignore build outputs and compilation artifacts
dist/
build/
out/
**/.next/
**/out/
**/coverage/
**/.swc/
**/bin/
**/obj/
**/.dotnet/
**/.vercel/

# Ignore database files and migrations (can grow to 100s MB)
**/db/
**/prisma/migrations/
**/Migrations/
*.db
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Ignore test outputs and fixtures
**/test-results/
**/__tests__/
**/__fixtures__/
**/fixtures/
**/e2e/

# Ignore operational and artifact logs
logs/
**/logs/
**/artifacts/
**/reports/
**/vault/

# Ignore large data files
*.csv
*.log
**/*.log
*.min.js
*.map
*.zip
*.7z
*.tmp
*.cache
**/screenshots/