@page
@model DocSmith.Pulse.Web.Pages.CalendarModel
@{
    ViewData["Title"] = "Calendar";
}

<h2>Weekly Calendar</h2>
<p><strong>Week:</strong> @Model.WeekStartUtc.ToString("yyyy-MM-dd") → @Model.WeekEndUtc.ToString("yyyy-MM-dd")</p>

<div class="mb-3 d-flex gap-2">
    <a asp-page="/Calendar" asp-route-weekStartUtc="@Model.WeekStartUtc.AddDays(-7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">Previous Week</a>
    <a asp-page="/Calendar" asp-route-weekStartUtc="@DateTime.UtcNow.Date.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">Current Week</a>
    <a asp-page="/Calendar" asp-route-weekStartUtc="@Model.WeekStartUtc.AddDays(7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">Next Week</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5>Schedule Approved Idea</h5>
        <form method="post" asp-page-handler="Schedule" class="row g-2">
            <div class="col-md-6">
                <select name="ideaId" class="form-select">
                    @foreach (var idea in Model.ApprovedIdeas)
                    {
                        <option value="@idea.Id">#@idea.Id - @idea.Topic</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <input type="datetime-local" name="scheduledForUtc" class="form-control" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100" disabled="@Model.IsPulseDisabled">Schedule</button>
            </div>
        </form>
    </div>
</div>

<table class="table table-sm table-bordered">
    <thead>
    <tr>
        @foreach (var day in Model.Days)
        {
            <th>@day.ToString("ddd yyyy-MM-dd")</th>
        }
    </tr>
    </thead>
    <tbody>
    <tr>
        @foreach (var day in Model.Days)
        {
            <td style="vertical-align:top; min-height: 180px;">
                @{
                    var items = Model.ScheduledByDay.TryGetValue(day.Date, out var v) ? v : new List<DocSmith.Pulse.Core.Entities.ContentIdea>();
                }
                @if (items.Count == 0)
                {
                    <span class="text-muted">No scheduled items</span>
                }
                else
                {
                    foreach (var i in items)
                    {
                        <div class="border rounded p-2 mb-2">
                            <div class="small"><strong>#@i.Id</strong> @i.ScheduledForUtc?.ToString("HH:mm") UTC</div>
                            <div>@i.Topic</div>
                        </div>
                    }
                }
            </td>
        }
    </tr>
    </tbody>
</table>
