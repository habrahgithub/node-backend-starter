@page
@model IndexModel
@{
    ViewData["Title"] = "DocSmith Pulse";
}

<div class="text-center mb-4">
    <h1 class="display-5">DocSmith Pulse</h1>
    <p class="lead">Organization-safe, local-first digital marketing operations console.</p>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5>Ideas</h5>
                <p>Capture topics and assign campaigns.</p>
                <a asp-page="/Ideas" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5>Drafts</h5>
                <p>Generate, approve, schedule, and export copy.</p>
                <a asp-page="/Drafts" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5>Daily Pulse</h5>
                <p>Action queue for today's manual posting and comments.</p>
                <a asp-page="/DailyPulse" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5>Safety</h5>
                <p>Kill switch, safe mode, and capability toggles.</p>
                <a asp-page="/Admin/Safety" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
</div>
