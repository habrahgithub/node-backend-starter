@page
@model DocSmith.Pulse.Web.Pages.EngagementModel
@{
    ViewData["Title"] = "Engagement";
}

<h2>Engagement Targets</h2>
<p class="text-muted">Paste post summary and URL to generate manual comment suggestions.</p>

<div class="card mb-3">
    <div class="card-body">
        <form method="post" asp-page-handler="Generate" class="row g-3">
            <div class="col-md-8">
                <label asp-for="Input.PostUrl" class="form-label">Post URL</label>
                <input asp-for="Input.PostUrl" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Input.AuthorName" class="form-label">Author Name</label>
                <input asp-for="Input.AuthorName" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Input.PostSummary" class="form-label">Post Summary</label>
                <textarea asp-for="Input.PostSummary" class="form-control" rows="5"></textarea>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary" disabled="@Model.IsPulseDisabled">Generate Comments</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Generated != null)
{
    <div class="card border-success mb-3">
        <div class="card-body">
            <h5 class="text-success">Generated Comments</h5>
            <label class="form-label">Short</label>
            <textarea class="form-control mb-2" rows="3" readonly>@Model.Generated.DraftCommentShort</textarea>
            <label class="form-label">Medium</label>
            <textarea class="form-control" rows="5" readonly>@Model.Generated.DraftCommentMedium</textarea>
        </div>
    </div>
}

<table class="table table-sm table-striped align-middle">
    <thead>
    <tr>
        <th>ID</th>
        <th>Author</th>
        <th>Status</th>
        <th>Created</th>
        <th>URL</th>
    </tr>
    </thead>
    <tbody>
    @if (Model.Targets.Count == 0)
    {
        <tr><td colspan="5">No engagement targets yet.</td></tr>
    }
    else
    {
        foreach (var target in Model.Targets)
        {
            <tr>
                <td>@target.Id</td>
                <td>@target.AuthorName</td>
                <td>@target.Status</td>
                <td>@target.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @if (string.IsNullOrWhiteSpace(target.PostUrl))
                    {
                        <span>-</span>
                    }
                    else
                    {
                        <a href="@target.PostUrl" target="_blank" rel="noopener noreferrer">Open</a>
                    }
                </td>
            </tr>
        }
    }
    </tbody>
</table>
