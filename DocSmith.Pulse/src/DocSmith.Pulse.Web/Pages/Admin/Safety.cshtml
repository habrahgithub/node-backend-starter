@page
@model DocSmith.Pulse.Web.Pages.Admin.SafetyModel
@{
    ViewData["Title"] = "Safety";
}

<h2>Admin Safety Controls</h2>

<div class="card mb-3">
    <div class="card-body">
        <form method="post" asp-page-handler="Save">
            <div class="form-check mb-2">
                <input asp-for="Input.GlobalKillSwitchEnabled" class="form-check-input" />
                <label asp-for="Input.GlobalKillSwitchEnabled" class="form-check-label">Global Kill Switch</label>
            </div>
            <div class="form-check mb-2">
                <input asp-for="Input.OrganizationSafeModeEnabled" class="form-check-input" />
                <label asp-for="Input.OrganizationSafeModeEnabled" class="form-check-label">Organization Safe Mode (Default ON)</label>
            </div>
            <div class="form-check mb-2">
                <input asp-for="Input.AiGenerationEnabled" class="form-check-input" />
                <label asp-for="Input.AiGenerationEnabled" class="form-check-label">AI Generation Enabled</label>
            </div>
            <div class="form-check mb-2">
                <input asp-for="Input.SchedulerEnabled" class="form-check-input" />
                <label asp-for="Input.SchedulerEnabled" class="form-check-label">Scheduler Enabled</label>
            </div>
            <div class="form-check mb-3">
                <input asp-for="Input.ExportsEnabled" class="form-check-input" />
                <label asp-for="Input.ExportsEnabled" class="form-check-label">Exports Enabled</label>
            </div>

            <button type="submit" class="btn btn-danger">Save Safety State</button>
        </form>
    </div>
</div>

<div class="alert alert-secondary">
    <strong>Updated:</strong> @Model.State.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC
</div>
