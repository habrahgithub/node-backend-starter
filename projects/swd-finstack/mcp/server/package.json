{
  "name": "swd-finstack-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for SWD Finstack financial management integration",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:http": "node server.js --transport=http",
    "start:stdio": "node server.js --transport=stdio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "mcp",
    "swd",
    "finstack",
    "financial",
    "integration"
  ],
  "author": "SWD Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.0",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.0.2",
    "vitest": "^1.2.2"
  }
}
