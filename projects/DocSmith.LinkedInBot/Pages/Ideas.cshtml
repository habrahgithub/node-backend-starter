@page
@model DocSmith.LinkedInBot.Pages.IdeasModel
@{
    ViewData["Title"] = "Ideas";
}

<h2>Post Ideas</h2>

<form method="post" asp-page-handler="Add">
    <div>
        <label>Topic</label><br/>
        <input name="Topic" style="width:520px" />
    </div>
    <div>
        <label>Persona</label><br/>
        <input name="Persona" value="SME Founder" />
    </div>
    <div>
        <label>Post Type</label><br/>
        <select name="PostType">
            <option>Tip</option>
            <option>Checklist</option>
            <option>Insight</option>
            <option>Case</option>
        </select>
    </div>
    <div>
        <label>Key Point (1 line)</label><br/>
        <input name="KeyPoint" style="width:520px" />
    </div>
    <div style="margin-top:10px;">
        <button type="submit">Add Idea</button>
    </div>
</form>

<hr/>

<table cellpadding="6" cellspacing="0" border="1">
    <thead>
    <tr>
        <th>ID</th>
        <th>Topic</th>
        <th>Persona</th>
        <th>Type</th>
        <th>Status</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var i in Model.Ideas)
    {
        <tr>
            <td>@i.Id</td>
            <td>@i.Topic</td>
            <td>@i.Persona</td>
            <td>@i.PostType</td>
            <td>@i.Status</td>
            <td>
                <form method="post" asp-page-handler="Generate" style="display:inline;">
                    <input type="hidden" name="id" value="@i.Id" />
                    <button type="submit">Generate 3 Drafts</button>
                </form>
                <a href="/Drafts?id=@i.Id" style="margin-left:10px;">View Drafts</a>
            </td>
        </tr>
    }
    </tbody>
</table>
