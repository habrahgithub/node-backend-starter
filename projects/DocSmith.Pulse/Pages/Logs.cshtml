@page
@model DocSmith.Pulse.Pages.LogsModel
@{
    ViewData["Title"] = "Logs";
}

<h2>Activity Logs</h2>

<table class="table table-striped table-sm align-middle">
    <thead>
    <tr>
        <th>ID</th>
        <th>At (UTC)</th>
        <th>Type</th>
        <th>Title</th>
        <th>Notes</th>
        <th>Metrics</th>
    </tr>
    </thead>
    <tbody>
    @if (Model.Logs.Count == 0)
    {
        <tr>
            <td colspan="6">No activity logs yet.</td>
        </tr>
    }
    else
    {
        foreach (var log in Model.Logs)
        {
            <tr>
                <td>@log.Id</td>
                <td>@log.ActivityAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@log.ActivityType</td>
                <td>@log.Title</td>
                <td>@log.Notes</td>
                <td>
                    <form method="post" asp-page-handler="UpdateMetrics" class="row g-1">
                        <input type="hidden" name="id" value="@log.Id" />
                        <div class="col-6">
                            <input type="number" min="0" name="impressions" value="@log.Impressions" placeholder="Impressions" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <input type="number" min="0" name="reactions" value="@log.Reactions" placeholder="Reactions" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <input type="number" min="0" name="comments" value="@log.Comments" placeholder="Comments" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <input type="number" min="0" name="clicks" value="@log.Clicks" placeholder="Clicks" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                        </div>
                    </form>
                </td>
            </tr>
        }
    }
    </tbody>
</table>
