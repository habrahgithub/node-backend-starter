@page
@model DocSmith.Pulse.Pages.DailyPulseModel
@{
    ViewData["Title"] = "Daily Pulse";
}

<h2>Daily Pulse</h2>

<div class="card mb-4">
    <div class="card-header">
        Today's Post
    </div>
    <div class="card-body">
        @if (Model.TodaysPost == null || Model.TodaysPost.PostIdea == null)
        {
            <p>No approved post is waiting.</p>
        }
        else
        {
            <p><strong>Idea #@Model.TodaysPost.PostIdeaId:</strong> @Model.TodaysPost.PostIdea.Topic</p>
            <p><strong>Variant:</strong> @Model.TodaysPost.VariantNo</p>

            <textarea class="form-control mb-3" rows="10" readonly>@Model.TodaysPost.DraftText

@Model.TodaysPost.Hashtags</textarea>

            <form method="post" asp-page-handler="MarkPosted">
                <input type="hidden" name="draftId" value="@Model.TodaysPost.Id" />
                <button type="submit" class="btn btn-success">Mark Posted</button>
            </form>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        Today's Comments
    </div>
    <div class="card-body">
        @if (Model.TodaysComments.Count == 0)
        {
            <p>No queued comments right now.</p>
        }
        else
        {
            foreach (var item in Model.TodaysComments)
            {
                <div class="border rounded p-3 mb-3">
                    <p class="mb-1"><strong>@item.AuthorName</strong> (@item.Status)</p>
                    <p class="mb-2"><strong>URL:</strong> @item.PostUrl</p>

                    <label class="form-label">Short Comment</label>
                    <textarea class="form-control mb-2" rows="3" readonly>@item.DraftCommentShort</textarea>

                    <label class="form-label">Medium Comment</label>
                    <textarea class="form-control mb-2" rows="5" readonly>@item.DraftCommentMedium</textarea>

                    <form method="post" asp-page-handler="MarkCommentUsed">
                        <input type="hidden" name="targetId" value="@item.Id" />
                        <button type="submit" class="btn btn-outline-primary">Mark Comment Used</button>
                    </form>
                </div>
            }
        }
    </div>
</div>
