<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DocSmith Pulse</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DocSmith.Pulse.Web.styles.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-page="/Index">DocSmith Pulse</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Ideas">Ideas</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Campaigns">Campaigns</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Drafts">Drafts</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Engagement">Engagement</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/MediaStudio">Media Studio</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/DailyPulse">Daily Pulse</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Calendar">Calendar</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Logs">Logs</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Admin/Audit">Audit</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" asp-page="/Admin/Safety">Safety</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    @await Component.InvokeAsync("SafetyBanner")
    @if (Context.Request.Query.ContainsKey("blocked"))
    {
        <div class="alert alert-danger py-2" role="alert">
            Action blocked by safety controls. Reason: @Context.Request.Query["blocked"]
        </div>
    }
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container-fluid">
        &copy; 2026 - DocSmith Pulse
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
