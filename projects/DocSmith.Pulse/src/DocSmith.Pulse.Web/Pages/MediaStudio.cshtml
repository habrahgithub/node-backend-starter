@page
@model DocSmith.Pulse.Web.Pages.MediaStudioModel
@{
    ViewData["Title"] = "Media Studio";
}

<h2>Media Studio</h2>
<p class="text-muted">Internet discovery + creative generation for digital media workflows.</p>

<div class="card mb-3">
    <div class="card-body">
        <h5>Internet Media Search</h5>
        <form method="post" asp-page-handler="SearchMedia" class="row g-2">
            <div class="col-md-10">
                <input asp-for="SearchQuery" class="form-control" placeholder="e.g. UAE payroll team working in office" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100" disabled="@Model.IsPulseDisabled">Search</button>
            </div>
        </form>
    </div>
</div>

@if (Model.ImageSuggestions.Count > 0 || Model.VideoSuggestions.Count > 0)
{
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <h5>Image Suggestions</h5>
            @foreach (var image in Model.ImageSuggestions)
            {
                <div class="border rounded p-2 mb-2 d-flex gap-2">
                    @if (!string.IsNullOrWhiteSpace(image.ThumbnailUrl))
                    {
                        <img src="@image.ThumbnailUrl" alt="thumbnail" style="width:96px; height:96px; object-fit:cover;" />
                    }
                    <div>
                        <div><strong>@image.Title</strong></div>
                        <div class="small">Source: @image.Source | License: @image.License</div>
                        <a href="@image.Url" target="_blank" rel="noopener noreferrer">Open source</a>
                    </div>
                </div>
            }
        </div>
        <div class="col-md-6">
            <h5>Video Suggestions</h5>
            @foreach (var video in Model.VideoSuggestions)
            {
                <div class="border rounded p-2 mb-2">
                    <div><strong>@video.Title</strong></div>
                    <div class="small">Source: @video.Source | License: @video.License</div>
                    <a href="@video.Url" target="_blank" rel="noopener noreferrer">Open source</a>
                </div>
            }
        </div>
    </div>
}

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5>Generate Image</h5>
                <form method="post" asp-page-handler="GenerateImage">
                    <textarea asp-for="ImagePrompt" class="form-control mb-2" rows="4" placeholder="Describe the image to generate"></textarea>
                    <button type="submit" class="btn btn-outline-primary" disabled="@Model.IsPulseDisabled">Generate Image</button>
                </form>

                @if (Model.GeneratedImage != null)
                {
                    <div class="mt-3">
                        <div class="small text-muted">@Model.GeneratedImage.Notes</div>
                        @if (!string.IsNullOrWhiteSpace(Model.GeneratedImage.DataUrl))
                        {
                            <img src="@Model.GeneratedImage.DataUrl" alt="Generated image" class="img-fluid mt-2 border rounded" />
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5>Generate Video Brief</h5>
                <form method="post" asp-page-handler="GenerateVideo">
                    <textarea asp-for="VideoPrompt" class="form-control mb-2" rows="4" placeholder="Describe the video objective"></textarea>
                    <button type="submit" class="btn btn-outline-primary" disabled="@Model.IsPulseDisabled">Generate Video Brief</button>
                </form>

                @if (Model.GeneratedVideo != null)
                {
                    <div class="mt-3">
                        <div class="small text-muted">@Model.GeneratedVideo.Notes</div>
                        <textarea class="form-control mt-2" rows="8" readonly>@Model.GeneratedVideo.BriefText</textarea>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5>Generate Diagram</h5>
                <form method="post" asp-page-handler="GenerateDiagram">
                    <textarea asp-for="DiagramPrompt" class="form-control mb-2" rows="4" placeholder="Describe the workflow"></textarea>
                    <button type="submit" class="btn btn-outline-primary" disabled="@Model.IsPulseDisabled">Generate Diagram</button>
                </form>

                @if (Model.GeneratedDiagram != null)
                {
                    <div class="mt-3">
                        <div class="small text-muted">@Model.GeneratedDiagram.Notes</div>
                        <textarea class="form-control mt-2" rows="8" readonly>@Model.GeneratedDiagram.MermaidText</textarea>
                        <pre class="mermaid mt-2">@Model.GeneratedDiagram.MermaidText</pre>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-body">
        <h5>Recent Media Records</h5>
        <table class="table table-sm table-striped">
            <thead>
            <tr>
                <th>At (UTC)</th>
                <th>Type</th>
                <th>Title</th>
                <th>Source</th>
                <th>Link</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.RecentMedia.Count == 0)
            {
                <tr><td colspan="5">No media records yet.</td></tr>
            }
            else
            {
                foreach (var m in Model.RecentMedia)
                {
                    <tr>
                        <td>@m.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@m.MediaAssetType</td>
                        <td>@m.Title</td>
                        <td>@m.Source</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(m.Url))
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a href="@m.Url" target="_blank" rel="noopener noreferrer">Open</a>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script type="module">
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
        mermaid.initialize({ startOnLoad: true });
    </script>
}
