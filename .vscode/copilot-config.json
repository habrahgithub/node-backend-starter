{
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false
  },
  
  "github.copilot.chat.enabled": true,
  "github.copilot.chat.locales": ["en"],

  "gitignore.location": "top",

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },

  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },

  "copilot.advanced": {
    "debug": false,
    "testmode": false,
    "disableSnippetSuggestions": false,
    "inlineSuggestCount": 3,
    "listTopK": 5,
    "modelSelection": "auto"
  },

  "mcpContextProviders": [
    {
      "name": "sonarqube",
      "enabled": true,
      "type": "mcp"
    },
    {
      "name": "workspace-context",
      "enabled": true,
      "type": "builtin"
    }
  ],

  "skillProviders": [
    {
      "path": "~/.agents/skills/deploy",
      "enabled": true
    },
    {
      "path": "~/.agents/skills/railway-docs",
      "enabled": true
    },
    {
      "path": "~/.agents/skills/database",
      "enabled": true
    }
  ],

  "aiCodingSkills": {
    "autoCompletion": true,
    "inlineCompletion": true,
    "codeExplanation": true,
    "codeRefactoring": true,
    "testGeneration": true,
    "docGeneration": true
  },

  "contextWindow": {
    "maxTokens": 8192,
    "fileContext": true,
    "projectContext": true,
    "gitContext": true
  }
}
