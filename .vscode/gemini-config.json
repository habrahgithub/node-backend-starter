{
  "gemini.enabled": true,
  "gemini.apiKey": "default",
  "gemini.model": "gemini-2.0-flash",
  "gemini.temperature": 0.7,

  "gemini.indexing": {
    "enabled": true,
    "exclude": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "*.db",
      "*.sqlite"
    ]
  },

  "gemini.mcp": {
    "enabled": true,
    "servers": [
      {
        "name": "sonarqube-mcp",
        "enabled": true,
        "description": "Code quality analysis"
      },
      {
        "name": "filesystem-mcp",
        "enabled": true,
        "description": "Workspace filesystem context"
      }
    ]
  },

  "gemini.skills": [
    {
      "name": "railway",
      "path": "~/.agents/skills/railway-docs",
      "enabled": true
    },
    {
      "name": "deployment",
      "path": "~/.agents/skills/deployment",
      "enabled": true
    },
    {
      "name": "database",
      "path": "~/.agents/skills/database",
      "enabled": true
    },
    {
      "name": "environment",
      "path": "~/.agents/skills/environment",
      "enabled": true
    }
  ],

  "gemini.codeCompletion": {
    "enabled": true,
    "debounceMs": 100,
    "maxSuggestions": 5,
    "contextLines": 50
  },

  "gemini.commands": [
    {
      "id": "gemini.codeReview",
      "title": "Code Review",
      "prompt": "Review this code for quality, security, and best practices"
    },
    {
      "id": "gemini.explainCode",
      "title": "Explain Code",
      "prompt": "Explain this code clearly and concisely"
    },
    {
      "id": "gemini.generateTests",
      "title": "Generate Tests",
      "prompt": "Generate comprehensive unit tests for this code"
    },
    {
      "id": "gemini.refactor",
      "title": "Refactor Code",
      "prompt": "Refactor this code for better readability and performance"
    },
    {
      "id": "gemini.generateDocs",
      "title": "Generate Documentation",
      "prompt": "Generate detailed documentation and comments for this code"
    }
  ],

  "gemini.contextAwareness": {
    "enabled": true,
    "codebaseContext": true,
    "gitContext": true,
    "projectStructure": true
  },

  "gemini.performance": {
    "cacheContext": true,
    "parallelRequests": true,
    "optimizeTokenUsage": true
  },

  "gemini.privacy": {
    "sendDiagnostics": false,
    "anonymizeData": true,
    "localProcessing": true
  }
}
