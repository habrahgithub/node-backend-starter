{
	"servers": {
		"next-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"next-devtools-mcp@0.3.6"
			]
		},
		"github": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:github_token}",
				"ghcr.io/github/github-mcp-server:0.30.3"
			]
		},
		"microsoftdocs": {
			"type": "http",
			"url": "https://learn.microsoft.com/api/mcp"
		},
		"railway": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@railway/mcp-server"
			]
		},
		"vercel": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@vercel/mcp-server"
			]
		},
		"figma": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@figma/mcp-server"
			]
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:0.32.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.32.0"
		},
		"io.github.netdata/mcp-server": {
			"type": "http",
			"url": "https://app.netdata.cloud/api/v1/mcp",
			"headers": {
				"Authorization": "Bearer ${input:NETDATA_CLOUD_API_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "2.9.0"
		},
		"io.github.ChromeDevTools/chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--registry",
				"https://registry.npmjs.org",
				"chrome-devtools-mcp@0.19.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.19.0"
		},
		"oraios/serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"serena@latest",
				"--context",
				"ide-assistant"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		}
	},
	"inputs": [
		{
			"id": "github_token",
			"type": "promptString",
			"description": "GitHub Personal Access Token for MCP server authentication",
			"password": true
		},
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		},
		{
			"id": "NETDATA_CLOUD_API_TOKEN",
			"type": "promptString",
			"description": "Netdata Cloud API token (create at app.netdata.cloud > User Settings > API Tokens with scope:mcp)",
			"password": true
		}
	]
}