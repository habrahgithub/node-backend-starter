  "skillsByCategory": {
    "deployment": ["railway", "deploy", "deployment"],
    "data": ["database"],
    "infrastructure": ["domain", "service"],
    "configuration": ["environment"],
    "monitoring": ["metrics", "status"],
    "initialization": ["new"],
    "project": ["projects"],
    "documentation": ["railway-docs"],
    "community": ["central-station"],
    "scaffolding": ["templates"]
  },

  "skillsByExtension": {
    "continue": ["railway", "database", "deploy", "deployment", "domain", "environment", "metrics", "new", "projects", "railway-docs", "service", "status", "templates", "central-station"],
    "cline": ["railway", "database", "deploy", "deployment", "domain", "environment", "metrics", "new", "projects", "railway-docs", "service", "status", "templates", "central-station"],
    "copilot": ["railway", "database", "deployment", "environment", "new", "railway-docs", "templates"],
    "gemini": ["railway", "database", "environment", "railway-docs"]
  }
}
